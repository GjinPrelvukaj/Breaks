---
const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="hero">
  <div class="wrap inner">
    <div class="rise" style="animation-delay: 60ms">
      <span class="pill"><span class="dot" aria-hidden="true"></span>Version 1.1 · Now available</span>
    </div>

    <h1 class="h-display headline rise" style="animation-delay: 140ms">
      A Pomodoro that<br />
      respects your attention.
    </h1>

    <p class="lede rise" style="animation-delay: 240ms">
      Breaks lives quietly in your menu bar. It tracks focus, keeps streaks,
      exports finished sessions to Calendar, and stays out of your way.
      No account. No analytics. No noise.
    </p>

    <div class="ctas rise" style="animation-delay: 320ms">
      <a class="btn btn-primary" href="https://github.com/GjinPrelvukaj/Breaks/releases/latest" rel="noopener">
        Download for macOS
      </a>
      <a class="btn btn-ghost" href="https://github.com/GjinPrelvukaj/Breaks" rel="noopener" target="_blank">
        View source
      </a>
    </div>

    <p class="meta-line rise" style="animation-delay: 400ms">
      Free &amp; open source · Universal binary · macOS 13 or later
    </p>

    <figure class="media rise" style="animation-delay: 480ms" aria-label="Breaks running in the macOS menu bar">
      <div class="frame glass">
        <div class="menubar" aria-hidden="true">
          <div class="mb-left">
            <span class="mb-apple">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16.4 1.7c0 1.2-.5 2.3-1.3 3.1-.9.9-2 1.6-3.2 1.5-.1-1.2.5-2.4 1.3-3.2.9-.9 2.1-1.4 3.2-1.4zM20.5 17.4c-.6 1.4-1 2.1-1.7 3.3-1.1 1.7-2.6 3.7-4.5 3.7-1.7 0-2.1-1.1-4.4-1.1s-2.7 1.1-4.4 1.1c-1.9 0-3.4-1.9-4.5-3.6C-1 16.5-1.5 11 .5 7.7c1.4-2.4 3.6-3.9 5.7-3.9 1.7 0 2.8 1 4.3 1 1.4 0 2.3-1 4.3-1 1.5 0 3.1.8 4.3 2.2-3.7 2-3.1 7.4 1.4 9.4z"/></svg>
            </span>
            <span class="mb-text bold">Finder</span>
            <span class="mb-text dim">File · Edit · View · Window · Help</span>
          </div>
          <div class="mb-right">
            <span class="mb-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <circle cx="12" cy="13" r="8" />
                <path d="M12 8v5l3 2" stroke-linecap="round" />
                <path d="M9 2h6" stroke-linecap="round" />
              </svg>
            </span>
            <span class="mb-text mono">23:47</span>
            <span class="mb-text dim">Tue 28 Apr</span>
          </div>
        </div>

        <div class="popover-wrap">
          <img
            src={`${BASE}/media/demo.gif`}
            alt="Breaks in action: opening the menu-bar popover, starting a focus session, viewing streaks and settings"
            width="1108"
            height="720"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>
    </figure>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(4rem, 10vw, 8rem);
    padding-bottom: clamp(3rem, 7vw, 5rem);
    overflow: hidden;
    text-align: center;
  }

  .inner {
    display: grid;
    gap: clamp(1rem, 2.2vw, 1.5rem);
    justify-items: center;
  }

  .pill .dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--amber);
  }

  .headline {
    max-width: 22ch;
  }

  .lede {
    font-size: clamp(1.05rem, 1.45vw, 1.2rem);
    color: var(--ink-dim);
    max-width: 56ch;
    line-height: 1.55;
    font-weight: 400;
  }

  .ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 0.6rem;
  }

  .meta-line {
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--ink-mute);
    letter-spacing: 0.04em;
    margin-top: 0.4rem;
  }

  .media {
    width: 100%;
    margin-top: clamp(2.5rem, 5vw, 4rem);
    text-align: left;
  }

  .frame {
    border-radius: 16px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 40px 100px -40px rgba(0, 0, 0, 0.7);
  }

  .menubar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 14px;
    height: 30px;
    background: rgba(0, 0, 0, 0.5);
    border-bottom: 1px solid var(--hair);
    font-size: 0.78rem;
    color: var(--ink-dim);
  }
  .mb-left,
  .mb-right {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
  }
  .mb-apple {
    display: inline-grid;
    place-items: center;
    color: var(--ink-dim);
  }
  .mb-apple svg {
    width: 12px;
    height: 12px;
  }
  .mb-text {
    line-height: 1;
  }
  .mb-text.bold {
    color: var(--ink);
    font-weight: 600;
  }
  .mb-text.dim {
    color: var(--ink-mute);
  }
  .mb-text.mono {
    font-family: var(--mono);
    font-size: 0.74rem;
  }
  .mb-icon {
    display: inline-grid;
    place-items: center;
    width: 22px;
    height: 22px;
    border-radius: 7px;
    color: var(--ink);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--hair-strong);
  }
  .mb-icon svg {
    width: 12px;
    height: 12px;
  }

  .popover-wrap {
    padding: clamp(1rem, 3vw, 2.4rem);
    display: grid;
    place-items: center;
  }
  .popover-wrap img {
    border-radius: 10px;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.04),
      0 14px 50px -14px rgba(0, 0, 0, 0.6);
    max-width: min(100%, 880px);
  }
</style>
