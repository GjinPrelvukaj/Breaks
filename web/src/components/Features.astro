---
const items = [
  {
    icon: "ai",
    title: "Breaks AI, on device.",
    body:
      "A weekly summary of where your focus went, plus a chat that answers questions about your journal. Apple Foundation Models, all local. No API keys, no servers.",
  },
  {
    icon: "menubar",
    title: "Lives in the menu bar.",
    body:
      "No Dock clutter, no extra window. A small icon, a quiet countdown, and a popover when you need it.",
  },
  {
    icon: "journal",
    title: "Tracks real focus.",
    body:
      "Pick a focus, label each block, and mark it good, messy, or skipped. Tag with a project to see week / month / all-time time per project.",
  },
  {
    icon: "streak",
    title: "Honest streaks.",
    body:
      "A weekly rest-day budget, sleep recovery, and idle prompts keep progress useful without punishing real life.",
  },
  {
    icon: "suggestions",
    title: "Six cycle templates.",
    body:
      "Pomodoro, 52/17, Deep Work, Flowtime, Ultradian, or Quick. One tap to switch, or tune the durations yourself.",
  },
  {
    icon: "calendar",
    title: "Calendar & Markdown.",
    body:
      "Optionally write completed focus blocks to Calendar. Or export your full focus journal as a Markdown file you own.",
  },
];
---

<section id="features" class="features">
  <div class="wrap">
    <header class="head">
      <span class="eyebrow">Features</span>
      <h2 class="h-section">A timer designed for the corner of your eye.</h2>
      <p class="lede">
        A small set of ideas, executed with care. None of them shout, all of
        them compound into a workday that feels less interrupted.
      </p>
    </header>

    <ul class="grid">
      {
        items.map((it) => (
          <li class="card">
            <div class="ico" aria-hidden="true">
              {it.icon === "ai" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <path d="M12 3.5l1.6 3.6L17 8.6l-3.4 1.4L12 13.6l-1.6-3.6L7 8.6l3.4-1.5L12 3.5z" stroke-linejoin="round" />
                  <path d="M18 14l.9 2 2 .9-2 .9-.9 2-.9-2-2-.9 2-.9.9-2z" stroke-linejoin="round" />
                  <path d="M5 17l.6 1.4L7 19l-1.4.6L5 21l-.6-1.4L3 19l1.4-.6L5 17z" stroke-linejoin="round" />
                </svg>
              )}
              {it.icon === "menubar" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <rect x="3" y="4" width="18" height="3" rx="1.4" />
                  <rect x="3" y="9" width="18" height="11" rx="2.2" />
                  <circle cx="6.6" cy="5.5" r="0.55" fill="currentColor" stroke="none" />
                  <circle cx="8.6" cy="5.5" r="0.55" fill="currentColor" stroke="none" />
                  <circle cx="10.6" cy="5.5" r="0.55" fill="currentColor" stroke="none" />
                  <circle cx="12.5" cy="14.5" r="3" />
                  <path d="M12.5 12.5v2.2l1.4 0.9" stroke-linecap="round" />
                </svg>
              )}
              {it.icon === "journal" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <rect x="4" y="3" width="16" height="18" rx="2.4" />
                  <path d="M8 8h8M8 12h8M8 16h5" stroke-linecap="round" />
                  <path d="M9 3v18" />
                </svg>
              )}
              {it.icon === "streak" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <path d="M12 2.5c2.4 4 4.8 6.5 4.8 10.2A4.8 4.8 0 0 1 12 17.5a4.8 4.8 0 0 1-4.8-4.8c0-3.7 2.4-6.2 4.8-10.2z" stroke-linejoin="round" />
                  <path d="M12 21l-2 -2.5M12 21l2 -2.5" stroke-linecap="round" />
                </svg>
              )}
              {it.icon === "suggestions" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <path d="M5 6.5h14M5 12h10M5 17.5h7" stroke-linecap="round" />
                  <path d="M17 14.5l2 2 3-4" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M3 4.5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v7.2" stroke-linecap="round" />
                  <path d="M3 4.5v15a2 2 0 0 0 2 2h9" stroke-linecap="round" />
                </svg>
              )}
              {it.icon === "calendar" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <rect x="4" y="5" width="16" height="15" rx="2.2" />
                  <path d="M8 3v4M16 3v4M4 9h16" stroke-linecap="round" />
                  <path d="M8 13h3v3H8zM14 13h2.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
              {it.icon === "keyboard" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <rect x="3" y="6" width="18" height="12" rx="2.4" />
                  <path d="M7 10h.01M11 10h.01M15 10h.01M7 14h10" stroke-linecap="round" />
                </svg>
              )}
            </div>
            <h3 class="card-title">{it.title}</h3>
            <p class="card-body">{it.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .features {
    padding-block: clamp(5rem, 10vw, 8rem);
    border-top: 1px solid var(--hair);
  }
  .head {
    display: grid;
    gap: 0.85rem;
    text-align: center;
    max-width: 60ch;
    margin: 0 auto clamp(2.5rem, 5vw, 4rem);
  }
  .head .lede {
    color: var(--ink-dim);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--hair);
    border: 1px solid var(--hair);
    border-radius: 18px;
    overflow: hidden;
  }
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .card {
    background: var(--bg-elev);
    padding: clamp(1.5rem, 3vw, 2rem);
    display: grid;
    gap: 0.6rem;
    align-content: start;
    transition: background 0.25s ease;
  }
  .card:hover {
    background: var(--bg-soft);
  }

  .ico {
    width: 32px;
    height: 32px;
    margin-bottom: 0.5rem;
    color: var(--ink-dim);
  }
  .ico svg {
    width: 100%;
    height: 100%;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .card-body {
    color: var(--ink-dim);
    font-size: 0.94rem;
    line-height: 1.6;
    max-width: 42ch;
  }
</style>
