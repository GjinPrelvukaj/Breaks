---
const items = [
  {
    icon: "menubar",
    title: "Lives in the menu bar.",
    body:
      "No Dock clutter, no rogue window. A small icon, a quiet countdown, a popover when you actually want one.",
  },
  {
    icon: "journal",
    title: "Built-in focus journal.",
    body:
      "Pick a focus, tag each block, mark it good or messy in one tap. A weekly review tells you where the time really went.",
  },
  {
    icon: "suggestions",
    title: "Editable break suggestions.",
    body:
      "Keep short and long break ideas that actually fit your day. Add, delete, reset, and cycle through them from the timer.",
  },
  {
    icon: "calendar",
    title: "Calendar export.",
    body:
      "Optionally write completed focus blocks to Calendar with your focus label, start time, and end time.",
  },
  {
    icon: "streak",
    title: "Streaks with grace.",
    body:
      "Each ISO week ships with a small pause-day budget. Miss a day, the streak doesn't crater. Built for sustainable practice.",
  },
  {
    icon: "lock",
    title: "Free and open source.",
    body:
      "MIT licensed. Sandboxed. No account, no analytics, no network. State lives on your Mac. Read the source, fork it, build your own.",
  },
  {
    icon: "sleep",
    title: "Survives sleep and idle.",
    body:
      "Driven by an end-date and macOS sleep notifications, so the timer doesn't drift. Walk away and idle detection asks if it still counts.",
  },
  {
    icon: "keyboard",
    title: "Global hotkeys.",
    body:
      "Start, skip, reset, even when Breaks isn't focused. Carbon-registered, so they fire when nothing else's listening.",
  },
];
---

<section id="features" class="features">
  <div class="wrap">
    <header class="head">
      <span class="eyebrow">Features</span>
      <h2 class="h-section">A timer designed for the corner of your eye.</h2>
      <p class="lede">
        Eight small ideas, executed with care. None of them shout, all of them
        compound into a workday that feels less interrupted.
      </p>
    </header>

    <ul class="grid">
      {
        items.map((it) => (
          <li class="card">
            <div class="ico" aria-hidden="true">
              {it.icon === "menubar" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <rect x="3" y="4" width="18" height="3" rx="1.4" />
                  <rect x="3" y="9" width="18" height="11" rx="2.2" />
                  <circle cx="6.6" cy="5.5" r="0.55" fill="currentColor" stroke="none" />
                  <circle cx="8.6" cy="5.5" r="0.55" fill="currentColor" stroke="none" />
                  <circle cx="10.6" cy="5.5" r="0.55" fill="currentColor" stroke="none" />
                  <circle cx="12.5" cy="14.5" r="3" />
                  <path d="M12.5 12.5v2.2l1.4 0.9" stroke-linecap="round" />
                </svg>
              )}
              {it.icon === "journal" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <rect x="4" y="3" width="16" height="18" rx="2.4" />
                  <path d="M8 8h8M8 12h8M8 16h5" stroke-linecap="round" />
                  <path d="M9 3v18" />
                </svg>
              )}
              {it.icon === "streak" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <path d="M12 2.5c2.4 4 4.8 6.5 4.8 10.2A4.8 4.8 0 0 1 12 17.5a4.8 4.8 0 0 1-4.8-4.8c0-3.7 2.4-6.2 4.8-10.2z" stroke-linejoin="round" />
                  <path d="M12 21l-2 -2.5M12 21l2 -2.5" stroke-linecap="round" />
                </svg>
              )}
              {it.icon === "suggestions" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <path d="M5 6.5h14M5 12h10M5 17.5h7" stroke-linecap="round" />
                  <path d="M17 14.5l2 2 3-4" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M3 4.5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v7.2" stroke-linecap="round" />
                  <path d="M3 4.5v15a2 2 0 0 0 2 2h9" stroke-linecap="round" />
                </svg>
              )}
              {it.icon === "calendar" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <rect x="4" y="5" width="16" height="15" rx="2.2" />
                  <path d="M8 3v4M16 3v4M4 9h16" stroke-linecap="round" />
                  <path d="M8 13h3v3H8zM14 13h2.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
              {it.icon === "lock" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <rect x="4" y="11" width="16" height="10" rx="2" />
                  <path d="M8 11V7.5a4 4 0 0 1 8 0V11" />
                  <circle cx="12" cy="16" r="1.4" />
                </svg>
              )}
              {it.icon === "sleep" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <path d="M21 13.5A9 9 0 0 1 10.5 3a8 8 0 1 0 10.5 10.5z" stroke-linejoin="round" />
                  <circle cx="16" cy="6" r="0.7" fill="currentColor" stroke="none" />
                  <circle cx="19" cy="9" r="0.5" fill="currentColor" stroke="none" />
                </svg>
              )}
              {it.icon === "keyboard" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <rect x="3" y="6" width="18" height="12" rx="2.4" />
                  <path d="M7 10h.01M11 10h.01M15 10h.01M7 14h10" stroke-linecap="round" />
                </svg>
              )}
            </div>
            <h3 class="card-title">{it.title}</h3>
            <p class="card-body">{it.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .features {
    padding-block: clamp(5rem, 10vw, 8rem);
    border-top: 1px solid var(--hair);
  }
  .head {
    display: grid;
    gap: 0.85rem;
    text-align: center;
    max-width: 60ch;
    margin: 0 auto clamp(2.5rem, 5vw, 4rem);
  }
  .head .lede {
    color: var(--ink-dim);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--hair);
    border: 1px solid var(--hair);
    border-radius: 18px;
    overflow: hidden;
  }
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .card {
    background: var(--bg-elev);
    padding: clamp(1.5rem, 3vw, 2rem);
    display: grid;
    gap: 0.6rem;
    align-content: start;
    transition: background 0.25s ease;
  }
  .card:hover {
    background: var(--bg-soft);
  }

  .ico {
    width: 32px;
    height: 32px;
    margin-bottom: 0.5rem;
    color: var(--ink-dim);
  }
  .ico svg {
    width: 100%;
    height: 100%;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .card-body {
    color: var(--ink-dim);
    font-size: 0.94rem;
    line-height: 1.6;
    max-width: 42ch;
  }
</style>
