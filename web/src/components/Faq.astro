---
const faqs = [
  {
    q: "Is Breaks really free?",
    a: "Yes. Free, MIT-licensed, no in-app purchases, no account, no analytics, nothing leaves your machine. State lives in macOS UserDefaults under the bundle ID.",
  },
  {
    q: "How does Breaks AI work? Is my data sent anywhere?",
    a: "No. Breaks AI runs entirely on your Mac through Apple Foundation Models. The weekly summary and the chat both read your local focus journal and answer locally — no API keys, no servers, no telemetry. It needs macOS 26 with Apple Intelligence enabled and an Apple Silicon Mac that supports it.",
  },
  {
    q: "Why the 'unidentified developer' warning?",
    a: "Breaks isn't notarized by Apple yet. Notarization requires a $99/year Apple Developer membership. Until then, right-click the app and choose Open on first launch, or run xattr -dr com.apple.quarantine /Applications/Breaks.app once.",
  },
  {
    q: "Does it work on Intel Macs?",
    a: "Yes. Releases ship as a universal binary (arm64 + x86_64), so the same zip runs on Apple Silicon and Intel Macs.",
  },
  {
    q: "What happens if I close my laptop mid-session?",
    a: "Breaks watches sleep and wake notifications, then reconciles the timer against an end-date so it doesn't drift. Open the lid an hour later and the session is right where it should be.",
  },
  {
    q: "What about idle time?",
    a: "If you walk away for longer than your idle threshold, Breaks notices and asks whether the just-elapsed time should still count toward the session. You decide.",
  },
  {
    q: "How do streaks survive missed days?",
    a: "Each ISO week comes with a small pause-day budget. The first N missed days that week are absorbed before the streak starts decaying. Configurable in settings.",
  },
  {
    q: "Can Breaks add completed sessions to Calendar?",
    a: "Yes, starting in v1.1. Calendar export is optional and only runs after you enable it in settings and grant macOS permission.",
  },
  {
    q: "Will there be auto-updates?",
    a: "Sparkle remains on the roadmap. For now, watch the GitHub repo or check Releases. New versions are tag-driven and ship the same day they're built.",
  },
  {
    q: "Where can I file bugs or request features?",
    a: "GitHub Issues is the right place. The roadmap is a public Project on the same repo.",
  },
];
---

<section id="faq" class="faq">
  <div class="wrap wrap-narrow">
    <header class="head">
      <span class="eyebrow">Frequently asked</span>
      <h2 class="h-section">Things people ask first.</h2>
    </header>

    <div class="list" itemscope itemtype="https://schema.org/FAQPage">
      {
        faqs.map((f) => (
          <details
            class="item"
            itemscope
            itemprop="mainEntity"
            itemtype="https://schema.org/Question"
          >
            <summary>
              <span itemprop="name" class="q">{f.q}</span>
              <span class="caret" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </summary>
            <div
              class="a"
              itemscope
              itemprop="acceptedAnswer"
              itemtype="https://schema.org/Answer"
            >
              <p itemprop="text">{f.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq {
    padding-block: clamp(5rem, 10vw, 8rem);
    border-top: 1px solid var(--hair);
  }
  .head {
    display: grid;
    gap: 0.85rem;
    text-align: center;
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }

  .list {
    border-top: 1px solid var(--hair);
  }
  .item {
    border-bottom: 1px solid var(--hair);
  }
  summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.4rem 0.25rem;
    transition: color 0.15s ease;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  summary:hover .q {
    color: var(--ink);
  }
  .q {
    font-size: clamp(1rem, 1.4vw, 1.05rem);
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: -0.005em;
    color: var(--ink);
    transition: color 0.15s ease;
  }
  .caret {
    width: 26px;
    height: 26px;
    display: grid;
    place-items: center;
    color: var(--ink-mute);
    transition: transform 0.25s ease, color 0.2s ease;
    flex-shrink: 0;
  }
  .caret svg {
    width: 14px;
    height: 14px;
  }
  .item[open] .caret {
    transform: rotate(180deg);
    color: var(--ink);
  }
  .a {
    overflow: hidden;
    padding: 0 0.25rem 1.4rem;
    color: var(--ink-dim);
    line-height: 1.65;
    font-size: 0.96rem;
    max-width: 64ch;
  }
  .item[open] .a {
    animation: drop 280ms ease both;
  }
  @keyframes drop {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
