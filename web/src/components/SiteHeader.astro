---
const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<header class="site-header">
  <div class="wrap row">
    <a href={`${BASE}/`} class="brand" aria-label="Breaks home">
      <span class="logo" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="13" r="8" />
          <path d="M12 8v5l3 2" stroke-linecap="round" />
          <path d="M9 2h6" stroke-linecap="round" />
        </svg>
      </span>
      <span class="brand-text">Breaks</span>
    </a>
    <nav class="nav">
      <a href="#features">Features</a>
      <a href="#screens">Screens</a>
      <a href="#install">Install</a>
      <a href="https://github.com/GjinPrelvukaj/Breaks" rel="noopener" target="_blank" class="gh-link">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12.02c0 5.1 3.29 9.42 7.86 10.95.58.1.79-.25.79-.55v-2.05c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.05-.71.08-.7.08-.7 1.16.08 1.78 1.2 1.78 1.2 1.04 1.78 2.72 1.27 3.39.97.1-.75.4-1.27.74-1.56-2.55-.29-5.24-1.27-5.24-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18a10.95 10.95 0 0 1 5.74 0c2.2-1.49 3.16-1.18 3.16-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.07 0 4.4-2.7 5.36-5.27 5.65.41.36.78 1.07.78 2.15v3.18c0 .31.21.66.8.55 4.57-1.53 7.86-5.85 7.86-10.95C23.5 5.65 18.35.5 12 .5z"/>
        </svg>
        <span class="sr">GitHub</span>
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    border-bottom: 1px solid var(--hair);
  }
  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--ink);
  }
  .logo {
    width: 22px;
    height: 22px;
    display: grid;
    place-items: center;
    color: var(--amber);
  }
  .logo svg {
    width: 100%;
    height: 100%;
  }
  .brand-text {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 24;
  }
  .nav {
    display: inline-flex;
    align-items: center;
    gap: clamp(0.85rem, 2.5vw, 1.6rem);
    font-size: 0.9rem;
    color: var(--ink-dim);
  }
  .nav a:not(.gh-link):hover {
    color: var(--ink);
  }
  .nav a:not(.gh-link) {
    transition: color 0.15s ease;
  }
  @media (max-width: 540px) {
    .nav a:not(.gh-link) {
      display: none;
    }
  }
  .gh-link {
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border: 1px solid var(--hair-strong);
    border-radius: 999px;
    color: var(--ink-dim);
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .gh-link:hover {
    color: var(--ink);
    border-color: var(--ink-dim);
  }
  .gh-link svg {
    width: 16px;
    height: 16px;
  }
  .sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
