---
const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");

const shots = [
  {
    file: "screenshot-stats.png",
    eyebrow: "Streaks",
    title: "See the rhythm without grading yourself.",
    body:
      "A heatmap of your year, a weekly review pulled from the journal, and a streak number that doesn't punish you for taking the day off.",
    alt: "Breaks stats page showing streak heatmap and weekly review",
  },
  {
    file: "screenshot-settings.png",
    eyebrow: "Settings",
    title: "Tune it once, forget it forever.",
    body:
      "Durations, sounds, hotkeys, idle threshold, pause-day budget. Every option in one collapsible page.",
    alt: "Breaks settings panel with collapsible sections for timer, sound, hotkeys",
  },
];
---

<section id="screens" class="screens">
  <div class="wrap">
    <header class="head">
      <span class="eyebrow">A look around</span>
      <h2 class="h-section">Designed for one job, sweated to the pixel.</h2>
    </header>

    {
      shots.map((s, i) => (
        <article class={`row ${i % 2 === 0 ? "alt-a" : "alt-b"}`}>
          <div class="copy">
            <span class="row-eyebrow">{s.eyebrow}</span>
            <h3 class="row-title">{s.title}</h3>
            <p class="row-body">{s.body}</p>
          </div>
          <figure class="visual glass">
            <img
              src={`${BASE}/media/${s.file}`}
              alt={s.alt}
              width="732"
              height="1100"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </article>
      ))
    }
  </div>
</section>

<style>
  .screens {
    padding-block: clamp(5rem, 10vw, 8rem);
    border-top: 1px solid var(--hair);
  }

  .head {
    display: grid;
    gap: 0.85rem;
    text-align: center;
    max-width: 56ch;
    margin: 0 auto clamp(2.5rem, 5vw, 4rem);
  }

  .row {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    padding-block: clamp(2rem, 4vw, 3.5rem);
  }
  .row + .row {
    border-top: 1px solid var(--hair);
  }

  @media (min-width: 880px) {
    .row {
      grid-template-columns: 1fr 1.05fr;
    }
    .row.alt-b .copy {
      order: 2;
    }
    .row.alt-b .visual {
      order: 1;
    }
  }

  .copy {
    display: grid;
    gap: 0.85rem;
    max-width: 46ch;
  }
  .row-eyebrow {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .row-title {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--ink);
  }
  .row-body {
    color: var(--ink-dim);
    font-size: 1.02rem;
    line-height: 1.6;
  }

  .visual {
    padding: clamp(1.25rem, 3vw, 2rem);
    display: grid;
    place-items: center;
    border-radius: 20px;
    aspect-ratio: 4 / 5;
  }
  .visual img {
    width: auto;
    max-height: 100%;
    max-width: 100%;
    border-radius: 12px;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.04),
      0 18px 50px -16px rgba(0, 0, 0, 0.6);
  }
</style>
