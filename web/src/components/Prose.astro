---
export interface Props {
  eyebrow: string;
  title: string;
  updated: string;
}

const { eyebrow, title, updated } = Astro.props;
---

<article class="prose">
  <div class="wrap wrap-narrow">
    <header class="head">
      <span class="eyebrow">{eyebrow}</span>
      <h1 class="h-section">{title}</h1>
      <p class="updated">Last updated {updated}</p>
    </header>
    <div class="body">
      <slot />
    </div>
  </div>
</article>

<style>
  .prose {
    padding-block: clamp(4rem, 8vw, 6rem);
  }
  .head {
    display: grid;
    gap: 0.75rem;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
    text-align: left;
  }
  .updated {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    color: var(--ink-mute);
    margin-top: 0.4rem;
  }

  .body {
    color: var(--ink-dim);
    font-size: 1.02rem;
    line-height: 1.7;
  }
  .body :global(h2) {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.015em;
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .body :global(h2:first-child) {
    margin-top: 0;
  }
  .body :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.01em;
    margin-top: 1.6rem;
    margin-bottom: 0.5rem;
  }
  .body :global(p + p) {
    margin-top: 1rem;
  }
  .body :global(ul),
  .body :global(ol) {
    margin: 0.8rem 0;
    padding-left: 1.4rem;
    display: grid;
    gap: 0.45rem;
  }
  .body :global(li) {
    line-height: 1.6;
  }
  .body :global(li::marker) {
    color: var(--ink-mute);
  }
  .body :global(a) {
    color: var(--ink);
    border-bottom: 1px solid var(--hair-strong);
    transition: border-color 0.15s ease;
  }
  .body :global(a:hover) {
    border-color: var(--ink);
  }
  .body :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }
  .body :global(hr) {
    border: 0;
    height: 1px;
    background: var(--hair);
    margin: 2.5rem 0;
  }
  .body :global(blockquote) {
    margin: 1.5rem 0;
    padding-left: 1rem;
    border-left: 2px solid var(--hair-strong);
    color: var(--ink-dim);
    font-style: italic;
  }
</style>
